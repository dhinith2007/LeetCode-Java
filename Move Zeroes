LEETCODE PROBLEM SOLVING
PROBLEM->MOVE ZEROES

class Solution {
    public void moveZeroes(int[] nums) {
        int index = 0;   // position to place non-zero elements
        
        for(int i = 0; i < nums.length; i++){
            if(nums[i] != 0){
                nums[index] = nums[i];
                index++;
            }
        }

        // fill remaining positions with zero
        while(index < nums.length){
            nums[index] = 0;
            index++;
        }
    }
}
